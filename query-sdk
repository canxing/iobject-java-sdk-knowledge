#!/bin/bash
#
# SDK 知识库查询脚本
#
# 包装脚本，用于在 Docker 容器中运行 query_client.py
# 自动检查并启动 sdk-kb 容器
#

set -e

# 配置
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONTAINER_NAME="sdk-kb"
IMAGE_NAME="sdk-kb:latest"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 打印带颜色的消息
print_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 检查 Docker 是否可用
check_docker() {
    if ! command -v docker &> /dev/null; then
        print_error "Docker 未安装或未在 PATH 中"
        echo "请先安装 Docker: https://docs.docker.com/get-docker/"
        exit 1
    fi

    if ! docker info &> /dev/null; then
        print_error "Docker 守护进程未运行"
        echo "请启动 Docker 服务"
        exit 1
    fi

    print_info "Docker 可用"
}

# 检查容器是否存在
check_container() {
    docker ps -a --filter "name=^${CONTAINER_NAME}$" --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"
}

# 检查容器是否正在运行
is_container_running() {
    docker ps --filter "name=^${CONTAINER_NAME}$" --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"
}

# 启动容器
start_container() {
    print_info "正在启动 ${CONTAINER_NAME} 容器..."

    # 检查镜像是否存在
    if ! docker images --format "{{.Repository}}:{{.Tag}}" | grep -q "^${IMAGE_NAME}$"; then
        print_warn "镜像 ${IMAGE_NAME} 不存在"
        print_info "请先构建镜像: docker build -t ${IMAGE_NAME} ."
        exit 1
    fi

    # 启动容器
    docker run -d \
        --name "${CONTAINER_NAME}" \
        -p 8000:8000 \
        -v "${PROJECT_ROOT}/data:/app/data:ro" \
        -v "${PROJECT_ROOT}/models:/app/models:ro" \
        "${IMAGE_NAME}"

    # 等待服务启动
    print_info "等待服务启动..."
    sleep 3

    # 检查服务健康状态
    local retries=10
    local count=0
    while [ $count -lt $retries ]; do
        if docker exec "${CONTAINER_NAME}" python -c "
import requests
try:
    r = requests.get('http://localhost:8000/health', timeout=2)
    exit(0 if r.status_code == 200 else 1)
except:
    exit(1)
" 2>/dev/null; then
            print_info "服务已就绪"
            return 0
        fi
        count=$((count + 1))
        sleep 2
    done

    print_error "服务启动超时"
    exit 1
}

# 确保容器运行
ensure_container() {
    if is_container_running; then
        print_info "容器 ${CONTAINER_NAME} 已在运行"
        return 0
    fi

    if check_container; then
        print_warn "容器 ${CONTAINER_NAME} 已存在但未运行"
        print_info "正在启动现有容器..."
        docker start "${CONTAINER_NAME}"

        # 等待服务启动
        print_info "等待服务启动..."
        sleep 2
    else
        start_container
    fi
}

# 显示帮助信息
show_help() {
    cat << 'EOF'
SDK 知识库查询工具

用法: query-sdk [选项] <查询文本>

选项:
    -h, --help          显示此帮助信息
    -t, --top N         返回 N 个结果 (默认: 5)
    -r, --raw           输出原始 JSON
    -c, --check         检查服务健康状态
    --stop              停止容器
    --restart           重启容器

示例:
    query-sdk "如何创建数据源"
    query-sdk "Workspace 打开方法" -t 10
    query-sdk "查询空间数据" --raw
    query-sdk --check

环境变量:
    SDK_API_URL         API 服务地址 (默认: http://localhost:8000)
EOF
}

# 停止容器
stop_container() {
    if check_container; then
        print_info "正在停止容器 ${CONTAINER_NAME}..."
        docker stop "${CONTAINER_NAME}" > /dev/null
        print_info "容器已停止"
    else
        print_warn "容器 ${CONTAINER_NAME} 不存在"
    fi
    exit 0
}

# 重启容器
restart_container() {
    if check_container; then
        print_info "正在重启容器 ${CONTAINER_NAME}..."
        docker restart "${CONTAINER_NAME}" > /dev/null
        print_info "容器已重启"
        # 等待服务启动
        sleep 3
    else
        print_warn "容器 ${CONTAINER_NAME} 不存在，将创建新容器"
        start_container
    fi
}

# 主函数
main() {
    # 解析参数
    local query=""
    local top_k=5
    local raw=false
    local check=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                show_help
                exit 0
                ;;
            -t|--top)
                top_k="$2"
                shift 2
                ;;
            -r|--raw)
                raw=true
                shift
                ;;
            -c|--check)
                check=true
                shift
                ;;
            --stop)
                stop_container
                ;;
            --restart)
                restart_container
                # 继续执行查询逻辑
                ;;
            -*)
                print_error "未知选项: $1"
                echo "使用 -h 或 --help 查看帮助"
                exit 1
                ;;
            *)
                # 收集查询文本
                if [ -z "$query" ]; then
                    query="$1"
                else
                    query="$query $1"
                fi
                shift
                ;;
        esac
    done

    # 检查 Docker
    check_docker

    # 检查模式
    if [ "$check" = true ]; then
        ensure_container
        docker exec "${CONTAINER_NAME}" python scripts/query_client.py --check
        exit $?
    fi

    # 检查查询文本
    if [ -z "$query" ]; then
        print_error "请提供查询文本"
        echo "使用 -h 或 --help 查看帮助"
        exit 1
    fi

    # 确保容器运行
    ensure_container

    # 构建命令参数
    local cmd_args=""
    if [ "$raw" = true ]; then
        cmd_args="--raw"
    fi

    # 执行查询
    docker exec "${CONTAINER_NAME}" python scripts/query_client.py "$query" --top "$top_k" $cmd_args
}

# 运行主函数
main "$@"
